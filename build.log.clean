For `classifyAndAssign`:
```
// System prompt: classify into 1-3 word group name, Title Case
// T4.6: Include existing group names to reduce proliferation
const allGroups = await browser.tabGroups.query({});
const existingNames = allGroups.map(g => g.title).filter(Boolean);

// T9.5: Cap existing groups list at MAX_GROUP_NAMES_IN_PROMPT, prioritize most tabs
let existingGroupsList = '';
if (existingNames.length > 0) {
  // Query all tabs to count by group
  const allTabs = await browser.tabs.query({});
  const tabCountByGroupId = {};
  for (const tab of allTabs) {
    if (tab.groupId > 0) {
      tabCountByGroupId[tab.groupId] = (tabCountByGroupId[tab.groupId] || 0) + 1;
    }
  }
  // Build map of groupId -> title
  const groupIdToTitle = {};
  for (const g of allGroups) {
    groupIdToTitle[g.id] = g.title;
  }
  // Sort groups by tab count descending, then take top MAX_GROUP_NAMES_IN_PROMPT
  const sortedGroups = allGroups
    .filter(g => g.title)
    .sort((a, b) => (tabCountByGroupId[b.id] || 0) - (tabCountByGroupId[a.id] || 0));
  
  const topGroups = sortedGroups.slice(0, MAX_GROUP_NAMES_IN_PROMPT);
  const topNames = topGroups.map(g => g.title).filter(Boolean);
  
  existingGroupsList = topNames.join(', ');
  
  if (sortedGroups.length > MAX_GROUP_NAMES_IN_PROMPT) {
    const remaining = sortedGroups.length - MAX_GROUP_NAMES_IN_PROMPT;
    existingGroupsList += `, ...and ${remaining} more`;
  }
}

const systemPrompt = existingGroupsList
  ? `Classify the following tab URL into a short group name (1-3 words, Title Case). Prefer reusing an existing group if applicable. Existing groups: [${existingGroupsList}]. Only create a new name if none fit. Return ONLY the group name.`
  : 'Classify the following tab URL into a short group name (1-3 words, Title Case). Respond with only the group name.';
```

