function extractDomain(url) {
  try {
    const parsed = new URL(url);
    if (parsed.protocol === 'http:' || parsed.protocol === 'https:') {
      return parsed.hostname;
    }
    return null; // non-http(s) protocol → skip
  } catch {
    return null; // malformed URL → skip
  }
}
```

