Let me write the final implementation:

```javascript
// TabTamer — content script
// T3.4 / T6.2: Notify background of SPA navigations (pushState/replaceState/popstate/hashchange)
// T7.5: Guard against double-patching and handle connect failures

// Guard: don't double-patch if this script runs twice
if (typeof window.__tabtamerPatched === 'undefined') {
  window.__tabtamerPatched = true;

  const origPush = history.pushState;
  const origReplace = history.replaceState;

  // Our wrapper functions (named for identity checks)
  function tabtamerPushState(...args) {
    origPush.apply(this, args);
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  }

  function tabtamerReplaceState(...args) {
    origReplace.apply(this, args);
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  }

  // Connect to background with retry; apply patches only after successful connection
  (function connect(retriesLeft) {
    let port;
    try {
      port = browser.runtime.connect({name: 'tabtamer-content'});
    } catch (err) {
      if (retriesLeft > 0) {
        const delay = 500 * Math.pow(2, 3 - retriesLeft); // ~500ms, 1s, 2s
        setTimeout(() => connect(retriesLeft - 1), delay);
      } else {
        console.warn('TabTamer: content script — cannot connect to background after retries', err);
        // Apply patches anyway (no restore-on-disconnect available)
        history.pushState = tabtamerPushState;
        history.replaceState = tabtamerReplaceState;
      }
      return;
    }

    port.onDisconnect.addListener(() => {
      // Only restore if our wrapper is still in place (T7.5: don't clobber other patchers)
      if (history.pushState === tabtamerPushState) {
        history.pushState = origPush;
      }
      if (history.replaceState === tabtamerReplaceState) {
        history.replaceState = origReplace;
      }
    });

    // Apply patches after connection established
    history.pushState = tabtamerPushState;
    history.replaceState = tabtamerReplaceState;
  })(3); // 3 retries

  window.addEventListener('popstate', () => {
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  });

  // T6.2: Catch hash-based SPA routers (e.g., example.com/#/page)
  window.addEventListener('hashchange', () => {
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  });
}
```

