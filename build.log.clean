Now let me understand what needs to be done for T7.5. The spec says:

**T7.5: Fix content.js monkey-patch fragility for `history.pushState`/`replaceState`**

If another extension also monkey-patches these, or if the TabTamer extension is reloaded without a page refresh, the patches can break. Add a guard:
- Store the original function reference once (before any patching); if already patched, don't double-patch.
- When the port disconnects, only restore if the current function is our wrapper.
- Also handle the case where `browser.runtime.connect` fails (e.g., background not ready) with retrying with exponential backoff or accepting that patching cannot be restored and logging a warning.

Let me think about the approach:

1. **Guard against double-patching**: We need to check if we already patched these functions. We can use a flag or check if the current function is our wrapper.

2. **Only restore if our wrapper**: When the port disconnects, check if `history.pushState` is currently our patched function before restoring. If another extension has since patched over ours, we shouldn't restore to our original.

3. **Handle `browser.runtime.connect` failures**: If the background script isn't ready yet, `connect()` might throw. We should retry with exponential backoff or log a warning if it can't connect.

Let me implement this:

```javascript
// TabTamer — content script
// T3.4 / T6.2: Notify background of SPA navigations (pushState/replaceState/popstate/hashchange)
// T7.5: Guard against double-patching and handle connect failures

(function() {
  // Guard: don't double-patch if this script runs twice
  if (window.__tabtamerPatched) return;
  window.__tabtamerPatched = true;

  const origPush = history.pushState;
  const origReplace = history.replaceState;

  // Our wrapper functions
  function patchedPush(...args) {
    origPush.apply(this, args);
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  }

  function patchedReplace(...args) {
    origReplace.apply(this, args);
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  }

  // T5.3 + T7.5: Connect to background, restore on disconnect
  function connectWithBackoff(retries = 3) {
    try {
      const port = browser.runtime.connect({name: "tabtamer-content"});
      port.onDisconnect.addListener(() => {
        // Only restore if our wrapper is still in place
        if (history.pushState === patchedPush) {
          history.pushState = origPush;
        }
        if (history.replaceState === patchedReplace) {
          history.replaceState = origReplace;
        }
      });
      // Apply patches only after successful connection
      history.pushState = patchedPush;
      history.replaceState = patchedReplace;
    } catch (err) {
      if (retries > 0) {
        setTimeout(() => connectWithBackoff(retries - 1), 1000 * Math.pow(2, 3 - retries));
      } else {
        console.warn('TabTamer: Could not connect to background after retries', err);
        // Still apply patches without restore capability
        history.pushState = patchedPush;
        history.replaceState = patchedReplace;
      }
    }
  }

  connectWithBackoff();

  window.addEventListener('popstate', () => {
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  });

  // T6.2: Catch hash-based SPA routers
  window.addEventListener('hashchange', () => {
    browser.runtime.sendMessage({ type: 'spaNavigate', url: location.href }).catch(() => {});
  });
})();
```

