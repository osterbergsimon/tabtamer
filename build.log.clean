// Phase 2: LLM-based merge of similar tab groups

async function mergeSimilarGroups() {
  try {
    // Check if extension is enabled
    if (!(await isEnabled())) {
      console.log('TabTamer: group merge — extension disabled, skipping');
      return;
    }

    // Check API key
